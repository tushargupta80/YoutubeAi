# Root env used by docker compose and shared local defaults

# Gemini
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-flash
DISABLE_CLOUD_FALLBACK=true

# Auth
AUTH_SECRET=replace_with_a_long_random_secret

# Database
# For local docker Postgres keep DB_SSL=false.
# If you switch the backend to Supabase in a hosted setup, use the Supabase DATABASE_URL inside backend/.env and set DB_SSL=true there.
VECTOR_STORE_PROVIDER=postgres
DB_SSL=false

# Ollama
OLLAMA_CHAT_MODEL=llama3
OLLAMA_PREPROCESS_MODEL=phi3:mini
OLLAMA_FALLBACK_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text
